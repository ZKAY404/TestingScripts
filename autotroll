local queueteleport = queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport)

local function compute_goal_cframe(target_root)
    local target_cf = target_root.CFrame
    local offset_cf = target_cf * CFrame.new(offset_x, offset_y, offset_z)
    local offset_pos = offset_cf.Position

    if rotate_as_target then
        return CFrame.new(offset_pos) * target_cf.Rotation
    else
        local dist = (offset_pos - target_cf.Position).Magnitude
        if dist < 0.01 then
            return CFrame.new(offset_pos) * target_cf.Rotation
        else
            return CFrame.lookAt(offset_pos, target_cf.Position)
        end
    end
end

local function get_target_char()
    if not selected_target then return nil end
    local player = players:FindFirstChild(selected_target)
    if player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        return player.Character
    end
    return nil
end

local function stop_sequence()
    is_running = false
    if sequence_conn then
        sequence_conn:Disconnect()
        sequence_conn = nil
    end
    local char = local_player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        if hum then
            hum.AutoRotate = true
            if env.sethiddenproperty then
                env.sethiddenproperty(hum, "PlatformStand", false)
            else
                hum.PlatformStand = false
            end
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
        if root then
            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
        end
    end
end

local function do_sequence()
    if not is_running then return end

    local char = local_player.Character
    if not char then return end

    local root = char:FindFirstChild("HumanoidRootPart")
    local torso = char:FindFirstChild("Torso")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not root or not torso or not hum then return end

    local target = get_target_char()
    if not target then
        warn("[Script] No target found: " .. tostring(selected_target))
        return
    end

    print("[Script] Starting sequence on: " .. target.Name)

    hum.AutoRotate = false
    if env.sethiddenproperty then
        env.sethiddenproperty(hum, "PlatformStand", true)
    else
        hum.PlatformStand = true
    end

    local elapsed = 0
    sequence_conn = run_service.Heartbeat:Connect(function(dt)
        if not is_running then
            sequence_conn:Disconnect()
            sequence_conn = nil
            return
        end

        elapsed = elapsed + dt

        local cur_char = local_player.Character
        if not cur_char then sequence_conn:Disconnect() sequence_conn = nil return end
        local cur_root = cur_char:FindFirstChild("HumanoidRootPart")
        local cur_torso = cur_char:FindFirstChild("Torso")
        local cur_hum = cur_char:FindFirstChildOfClass("Humanoid")
        local cur_target_root = target:FindFirstChild("HumanoidRootPart")
        if not cur_root or not cur_torso or not cur_hum or not cur_target_root then
            sequence_conn:Disconnect()
            sequence_conn = nil
            return
        end

        if env.sethiddenproperty then
            env.sethiddenproperty(cur_hum, "PlatformStand", true)
        end

        local goal_cf = compute_goal_cframe(cur_target_root)
        cur_torso.CFrame = goal_cf
        cur_root.AssemblyLinearVelocity = Vector3.zero
        cur_root.AssemblyAngularVelocity = Vector3.zero

        pcall(function() cur_hum:Move(Vector3.zero) end)

        if env.sethiddenproperty then
            env.sethiddenproperty(cur_root, "PhysicsRepRootPart", cur_target_root)
        end

        if elapsed >= 7 then
            sequence_conn:Disconnect()
            sequence_conn = nil

            -- press num 1
            vim:SendKeyEvent(true, Enum.KeyCode.One, false, game)
            task.wait(0.001)
            vim:SendKeyEvent(false, Enum.KeyCode.One, false, game)
            print("[Script] Pressed Num 1")

            task.wait(0.5)

            if is_running then
                print("[Script] Rejoining...")
                if queueteleport then
                    queueteleport(string.format([[
                        getgenv().Target = %q
                        getgenv().Running = true
                        repeat wait() until game.Players.LocalPlayer
                        loadstring(game:HttpGet("https://raw.githubusercontent.com/ZKAY404/TestingScripts/refs/heads/main/autotroll))()
                    ]], selected_target))
                end
                teleport_service:TeleportToPlaceInstance(game.PlaceId, game.JobId, local_player)
            end
        end
    end)
    print("[Script] Pressed Num 1 on start")
end


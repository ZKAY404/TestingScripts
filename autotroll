local ITEM_HEIGHT = 28

local function close_dropdown()
    dropdown_open = false
    dropdown_frame.Visible = false
    dropdown_arrow.Text = "▾"
end

local function populate_dropdown()
    for _, child in ipairs(dropdown_scroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    local count = 0
    for _, player in ipairs(players:GetPlayers()) do
        if player ~= local_player then
            count = count + 1
            local item = Instance.new("TextButton")
            item.BackgroundColor3 = Color3.fromRGB(36, 36, 52)
            item.BorderSizePixel = 0
            item.Size = UDim2.new(1, 0, 0, ITEM_HEIGHT)
            item.Font = Enum.Font.Gotham
            item.Text = player.Name
            item.TextColor3 = Color3.fromRGB(200, 200, 240)
            item.TextSize = 12
            item.ZIndex = 11
            item.LayoutOrder = count
            item.Parent = dropdown_scroll
            Instance.new("UICorner", item).CornerRadius = UDim.new(0, 4)
            item.MouseEnter:Connect(function() item.BackgroundColor3 = Color3.fromRGB(60, 60, 90) end)
            item.MouseLeave:Connect(function() item.BackgroundColor3 = Color3.fromRGB(36, 36, 52) end)
            item.MouseButton1Click:Connect(function()
                selected_target = player.Name
                getgenv().Target = selected_target
                dropdown_btn.Text = player.Name
                close_dropdown()
            end)
        end
    end
    local total_height = (count * (ITEM_HEIGHT + 2)) + 8
    dropdown_scroll.CanvasSize = UDim2.new(0, 0, 0, total_height)
    dropdown_frame.Size = UDim2.new(1, -24, 0, math.min(total_height, MAX_DROPDOWN_HEIGHT))
end

dropdown_btn.MouseButton1Click:Connect(function()
    if dropdown_open then close_dropdown()
    else
        populate_dropdown()
        dropdown_frame.Visible = true
        dropdown_open = true
        dropdown_arrow.Text = "▴"
    end
end)

